    "version": "0.2.0",
    "configurations": [
        {
            "name": "dna_seq_c++",
            "cwd": "/home/ajay/code/epi_2019/dna_sequencing",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/ajay/code/epi_2019/dna_sequencing/dna_sequencer_debug",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Boyer Moore match",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            //"args": ["-r",  "lambda_virus.fa",  "-s",  "sample.fasta", "-b"]
            //"args": ["-r",  "ref.fasta",  "-s",  "sample.fasta", "-b", "-t"]
            "args": ["-r",  "chr1.GRCh38.excerpt.fasta",  "-s",  "sample.fasta", "-b"]
        },

        {
            "name": "Pigeon Hole",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            //"args": ["-r",  "lambda_virus.fa",  "-s",  "sample.fasta", "-b"]
            //"args": ["-r",  "ref.fasta",  "-s",  "sample.fasta", "-b", "-t"]
            //"args": ["-r",  "chr1.GRCh38.excerpt.fasta",  "-s",  "sample.fasta", "-p", "-k", "8", "-m", "2"]
            "args": ["-r",  "chr1.GRCh38.excerpt.fasta",  "-s",  "sample.fasta", "-p", "-k", "8", "-m", "2", "-i", "3"]
        },

        {
            "name": "Naive Match",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            //"args": ["-r",  "lambda_virus.fa",  "-s",  "sample.fasta"]
            //"args": ["-r",  "ref.fasta",  "-s",  "sample.fasta"]
            "args": ["-r",  "chr1.GRCh38.excerpt.fasta",  "-s",  "sample.fasta"]
        },

        {
            "name": "Naive Match with reverse complement",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["-r",  "lambda_virus.fa",  "-s",  "sample.fasta", "-c"]
        },

        {
            "name": "Overlap finder",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["-o",  "-s", "ERR266411_1.for_asm.fastq",  "-k",  "30"]
        },

        {
            "name": "Greedy SCS",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["-g",  "-s", "ads1_week4_reads.fq",  "-k",  "30"]
        }
    ]
}